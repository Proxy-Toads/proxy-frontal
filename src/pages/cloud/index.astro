---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Cloud | ProxyToads'
const description =
  'Scalable and secure cloud infrastructure on AWS, Azure and Google Cloud. Architecture, migration, DevOps and security for businesses that want to grow without limits.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Cloud"
    title="Limitless cloud infrastructure for your business"
    subtitle="We design, migrate and manage your infrastructure on the world's best cloud providers with security, scalability and controlled costs."
    ctaLabel="Request an architecture review"
    ctaHref="mailto:hello@proxytoads.com"
    ctaSecondaryLabel="See services"
    ctaSecondaryHref="#services"
    breadcrumb={[{ label: 'Cloud', href: '/cloud/' }]}
  />

  <section id="services" class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Our services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">
        Everything you need to operate in the cloud
      </h2>
      <p class="text-dim text-lg max-w-2xl mb-16">
        From on-premise to cloud, or from cloud to a modern architecture. We're with your business at every stage of the cloud journey.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <a href="/cloud/aws-infraestructura/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">AWS / Infrastructure</h3>
          <p class="text-dim leading-relaxed mb-4">Architecture, migration and management of Amazon Web Services infrastructure with high availability and optimised costs.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>

        <a href="/cloud/tecnologia-cloud/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">Cloud Technology</h3>
          <p class="text-dim leading-relaxed mb-4">Containers, Kubernetes, microservices and serverless architectures for modern platforms that scale with your business.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>

        <a href="/cloud/seguridad-devops/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">Security / DevOps</h3>
          <p class="text-dim leading-relaxed mb-4">CI/CD, monitoring, secrets management and proactive security so your team deploys fast and safely.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-brand mb-2">99.9%</p>
        <p class="text-dim text-sm">Guaranteed uptime</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">−40%</p>
        <p class="text-dim text-sm">Infrastructure savings</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">3</p>
        <p class="text-dim text-sm">Supported cloud providers</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">ISO</p>
        <p class="text-dim text-sm">27001 compliance</p>
      </div>
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Cloud providers</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">
        Certified experts across all three major providers
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { name: 'Amazon Web Services', desc: 'The market-leading provider. Power, scale and the most complete cloud services ecosystem in the world.' },
          { name: 'Microsoft Azure', desc: 'Native integration with the Microsoft ecosystem. Ideal for businesses already using Office 365 or other Microsoft services.' },
          { name: 'Google Cloud Platform', desc: "The world's best network infrastructure and the most advanced AI and analytics tools on the market." },
        ].map(({ name, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="text-lg font-semibold text-ink mb-2">{name}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
