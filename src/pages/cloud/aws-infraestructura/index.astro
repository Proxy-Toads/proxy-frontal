---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'AWS & Cloud Infrastructure | ProxyToads'
const description =
  'Architecture, migration and management of AWS infrastructure. We design secure, scalable and cost-efficient cloud environments tailored to your business needs.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AWS / Infrastructure"
    title="AWS infrastructure designed to scale without surprises"
    subtitle="We design and manage Amazon Web Services architectures that adapt to your company's growth with high availability, proven security and controlled costs."
    ctaLabel="Review my architecture"
    ctaHref="mailto:hello@proxytoads.com"
    ctaSecondaryLabel="See providers"
    ctaSecondaryHref="#providers"
    breadcrumb={[
      { label: 'Cloud', href: '/cloud/' },
      { label: 'AWS / Infrastructure', href: '/cloud/aws-infraestructura/' },
    ]}
  />

  <section id="providers" class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Providers</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">Certified experts across all three major cloud providers</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">We work with AWS, Azure and GCP so you always use the provider that best fits your needs — no lock-in.</p>

      <div class="grid md:grid-cols-2 gap-8 max-w-3xl">
        <a href="/cloud/aws-infraestructura/aws/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">AWS</h3>
          <p class="text-dim leading-relaxed mb-4">The cloud market leader. EC2, S3, Lambda, RDS, EKS and the full Amazon ecosystem for infrastructures of any size.</p>
          <span class="text-brand text-sm font-medium">Learn more →</span>
        </a>

        <a href="/cloud/aws-infraestructura/azure-gcp/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">Azure / GCP</h3>
          <p class="text-dim leading-relaxed mb-4">Microsoft Azure for Microsoft-heavy environments and Google Cloud Platform for cutting-edge AI and analytics. Multi-cloud strategy where needed.</p>
          <span class="text-brand text-sm font-medium">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Infrastructure services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">Everything your cloud infrastructure needs</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Architecture design', desc: 'Well-Architected frameworks that balance cost, performance, security and reliability.' },
          { title: 'Cloud migration', desc: 'Safe migration from on-premise or between cloud providers with zero downtime.' },
          { title: 'Cost optimisation', desc: 'Audit and adjustment of resources to eliminate waste and right-size workloads.' },
          { title: 'High availability', desc: 'Multi-zone design, auto-scaling and load balancing to guarantee 99.9% uptime.' },
          { title: 'Managed databases', desc: 'RDS, Aurora, DynamoDB and other options configured for performance and disaster recovery.' },
          { title: 'Networking & perimeter security', desc: 'VPC, subnets, security groups, WAF and certificate management to isolate and protect your infrastructure.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
