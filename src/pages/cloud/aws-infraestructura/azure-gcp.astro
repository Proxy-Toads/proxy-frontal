---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Azure & Google Cloud Platform | ProxyToads'
const description =
  'Migration and management on Microsoft Azure and Google Cloud Platform. Multi-cloud strategy, solution architecture and optimisation for businesses that want provider flexibility.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Azure / GCP · Infrastructure"
    title="Microsoft Azure and Google Cloud at your company's service"
    subtitle="We help you get the best out of Microsoft Azure and Google Cloud Platform with multi-cloud strategies, robust architectures and continuous management — so you always pick the right provider for each job."
    ctaLabel="Discuss cloud strategy"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Cloud', href: '/cloud/' },
      { label: 'AWS / Infrastructure', href: '/cloud/aws-infraestructura/' },
      { label: 'Azure / GCP', href: '/cloud/aws-infraestructura/azure-gcp/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Microsoft Azure</p>
          <h2 class="text-2xl font-bold text-ink mb-4 text-center">Microsoft's cloud for enterprise environments</h2>
          <p class="text-dim mb-8 leading-relaxed text-center">The natural choice for businesses already living in the Microsoft ecosystem. Native integration with Office 365, Active Directory and the full enterprise productivity stack.</p>
          <div class="space-y-4">
            {[
              { title: 'Azure Active Directory', desc: 'Identity and access management integrated with your corporate Active Directory.' },
              { title: 'Azure DevOps', desc: 'CI/CD pipelines, repos and project management in a native Microsoft environment.' },
              { title: 'Azure OpenAI Service', desc: 'Access to GPT-4 and other LLMs directly within your Azure infrastructure.' },
              { title: 'Azure Kubernetes Service', desc: 'Managed Kubernetes with deep integration across the Microsoft ecosystem.' },
            ].map(({ title, desc }) => (
              <div class="p-4 rounded-lg border border-line bg-surface">
                <h3 class="font-medium text-ink mb-1">{title}</h3>
                <p class="text-dim text-sm">{desc}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Google Cloud Platform</p>
          <h2 class="text-2xl font-bold text-ink mb-4 text-center">The infrastructure that powers Google, for your business</h2>
          <p class="text-dim mb-8 leading-relaxed text-center">The world's best network infrastructure and the most advanced AI and analytics tools on the market. Ideal for companies with large data volumes or machine learning needs.</p>
          <div class="space-y-4">
            {[
              { title: 'BigQuery', desc: 'Serverless data warehouse to analyse terabytes of data in seconds at minimal cost.' },
              { title: 'Vertex AI', desc: 'Unified platform for training, deploying and managing machine learning models.' },
              { title: 'GKE (Google Kubernetes Engine)', desc: 'Kubernetes where it was born: the most mature and complete container orchestration environment.' },
              { title: 'Cloud Run', desc: 'Serverless containers that scale to zero automatically. No cluster management needed.' },
            ].map(({ title, desc }) => (
              <div class="p-4 rounded-lg border border-line bg-surface">
                <h3 class="font-medium text-ink mb-1">{title}</h3>
                <p class="text-dim text-sm">{desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Multi-cloud strategy</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">When to use each provider</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: 'Choose AWS if…', desc: 'You need the widest ecosystem of services, the largest community and the undisputed cloud market leader.' },
          { title: 'Choose Azure if…', desc: 'You already use Microsoft 365, Active Directory or Microsoft products and want native integration without friction.' },
          { title: 'Choose GCP if…', desc: 'Your business works with large data volumes, machine learning or you want the best global network infrastructure.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
