---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Amazon Web Services (AWS) | ProxyToads'
const description =
  'Specialised AWS services: Well-Architected design, cloud migration, cost optimisation and ongoing infrastructure management on Amazon Web Services.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AWS · Infrastructure"
    title="AWS experts for your cloud infrastructure"
    subtitle="We design, migrate and optimise your infrastructure on Amazon Web Services with proven architectures, first-class security and costs under control from day one."
    ctaLabel="Review my AWS architecture"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Cloud', href: '/cloud/' },
      { label: 'AWS / Infrastructure', href: '/cloud/aws-infraestructura/' },
      { label: 'AWS', href: '/cloud/aws-infraestructura/aws/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">AWS services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">The AWS services that generate the most impact for your business</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">We work across the entire AWS ecosystem, but specialise in the services that deliver the most value to growing companies.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'EC2 & Auto Scaling', desc: 'Virtual servers with automatic scaling to handle any load without over-provisioning or running out of resources.' },
          { title: 'S3 & storage', desc: 'Infinitely scalable, cost-effective object storage with 99.999999999% durability.' },
          { title: 'Lambda & Serverless', desc: 'Code that runs without managing servers. Pay only per actual execution, scales to zero when idle.' },
          { title: 'RDS & Aurora', desc: 'Managed relational databases with automatic backups, high availability and optimised performance.' },
          { title: 'EKS & containers', desc: 'AWS-managed Kubernetes to orchestrate Docker containers in production with fewer operational overheads.' },
          { title: 'VPC & networking', desc: 'Isolated virtual private networks with full control over routing, subnets and perimeter security.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Our services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">How we help you with AWS</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          { title: 'AWS Well-Architected design', desc: 'Architectures that meet the 6 pillars of the AWS framework: operations, security, reliability, performance, cost and sustainability.' },
          { title: 'Migration from on-premise or between clouds', desc: 'Planned migration with lift-and-shift, re-platforming or re-architecting strategy depending on your case.' },
          { title: 'Cost optimisation', desc: 'AWS account audit, instance right-sizing, Savings Plans and elimination of forgotten resources.' },
          { title: 'Management & operations', desc: 'Monitoring, alerts, incident management and continuous infrastructure updates so you can forget about servers.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
