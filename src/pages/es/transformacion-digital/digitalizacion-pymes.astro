---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Digitalización de Pymes | Transformación Digital | ProxyToads'
const description =
  'Digitalización completa para pequeñas y medianas empresas. Elimina el papel, adopta herramientas digitales y moderniza tu operación con un plan realista y presupuesto claro.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Digitalización de Pymes"
    title="Tu pyme, digitalizada y lista para crecer"
    subtitle="Llevamos a las pequeñas y medianas empresas al mundo digital con herramientas adecuadas, un plan adaptado a su presupuesto y acompañamiento en cada paso del camino."
    ctaLabel="Empezar ahora"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Transformación Digital', href: '/es/transformacion-digital/' },
      { label: 'Digitalización de Pymes', href: '/es/transformacion-digital/digitalizacion-pymes/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Áreas de digitalización</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Todo lo que tu pyme necesita para dar el salto digital</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">Abordamos la digitalización de forma integral, priorizando las áreas con mayor impacto en tu operación y rentabilidad.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Cero papel', desc: 'Digitalización de contratos, facturas, albaranes y documentación interna. Todo accesible desde cualquier dispositivo.' },
          { title: 'Gestión de clientes (CRM)', desc: 'Implementación y configuración de un CRM adaptado a tu equipo para gestionar clientes y oportunidades de venta.' },
          { title: 'Facturación electrónica', desc: 'Adopción de facturación digital con cumplimiento normativo y conexión a tu contabilidad.' },
          { title: 'Comunicación interna', desc: 'Herramientas de comunicación y colaboración para que tu equipo trabaje mejor, desde cualquier lugar.' },
          { title: 'Presencia digital', desc: 'Web profesional, Google My Business y presencia en redes sociales configurada para generar negocio.' },
          { title: 'Almacenamiento cloud', desc: 'Migración de archivos a la nube con acceso seguro, versionado y colaboración en tiempo real.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-brand mb-2">−80%</p>
        <p class="text-dim text-sm">Reducción de papel</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">45 días</p>
        <p class="text-dim text-sm">Digitalización completa</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">+150</p>
        <p class="text-dim text-sm">Pymes digitalizadas</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">2×</p>
        <p class="text-dim text-sm">Velocidad operativa</p>
      </div>
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Nuestro compromiso</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">Por qué las pymes confían en ProxyToads</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          'Precios transparentes y adaptados al tamaño de tu empresa',
          'Formación incluida para que tu equipo use las herramientas con soltura',
          'Sin jerga técnica: te explicamos todo en lenguaje claro',
          'Soporte post-implementación para resolver cualquier duda',
          'Plan por fases para no asumir todo el costo a la vez',
          'Herramientas open-source cuando es posible para reducir costos recurrentes',
        ].map(item => (
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-brand/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-dim">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
