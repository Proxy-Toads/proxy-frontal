---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Herramientas de IA | Automatización | ProxyToads'
const description =
  'Implementación y configuración de herramientas IA: GPT-4, Claude, Gemini y más. Integración con tus sistemas actuales para multiplicar la productividad de tu equipo.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Herramientas de IA"
    title="Las mejores herramientas de IA, configuradas para tu negocio"
    subtitle="Seleccionamos, configuramos y optimizamos las herramientas de Inteligencia Artificial más potentes del mercado para que encajen exactamente en tu flujo de trabajo."
    ctaLabel="Consultoría gratuita"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Automatización con IA', href: '/es/automatizacion-ia/' },
      { label: 'Herramientas de IA', href: '/es/automatizacion-ia/herramientas-ia/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Herramientas que implementamos</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">El ecosistema IA al servicio de tu empresa</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">No te vendemos una herramienta genérica. Evaluamos tu caso y elegimos la combinación de IA que mejor resultado dará en tu contexto específico.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Modelos de lenguaje (LLMs)', desc: 'GPT-4o, Claude 3.5, Gemini Pro y Llama para generación de texto, respuestas, resúmenes y análisis de contenido.' },
          { title: 'RAG y bases de conocimiento', desc: 'Conecta la IA a tus documentos internos para que responda con datos precisos de tu propia empresa.' },
          { title: 'Generación de imágenes', desc: 'DALL-E, Midjourney y Stable Diffusion para creación de assets visuales automatizada.' },
          { title: 'Transcripción y voz', desc: 'Whisper y otros modelos para transcribir reuniones, llamadas y crear flujos de voz a texto.' },
          { title: 'Agentes IA autónomos', desc: 'Agentes que razonan, planifican y ejecutan tareas complejas de múltiples pasos sin intervención humana.' },
          { title: 'Análisis y clasificación', desc: 'Modelos especializados para clasificar documentos, analizar sentimiento y extraer datos estructurados.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 border-t border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Cómo trabajamos</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">Del descubrimiento a la producción</h2>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Auditoría de casos de uso', desc: 'Identificamos dónde la IA puede generar más valor en tu operación actual.' },
          { step: '02', title: 'Selección de herramientas', desc: 'Elegimos las herramientas óptimas según tu caso, presupuesto y stack tecnológico.' },
          { step: '03', title: 'Integración y configuración', desc: 'Conectamos la IA a tus sistemas y la ajustamos para tu contexto específico.' },
          { step: '04', title: 'Medición y optimización', desc: 'Monitorizamos el rendimiento y mejoramos los modelos con datos reales.' },
        ].map(({ step, title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <p class="text-3xl font-bold text-brand/20 mb-4">{step}</p>
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
