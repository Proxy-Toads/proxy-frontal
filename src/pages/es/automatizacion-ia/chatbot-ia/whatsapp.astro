---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Chatbot IA para WhatsApp | ProxyToads'
const description =
  'Chatbot con IA para WhatsApp Business. Responde automáticamente, gestiona pedidos, cualifica leads y atiende clientes 24/7 con integración CRM y flujos personalizados.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Chatbot IA · WhatsApp"
    title="Tu asistente IA en el WhatsApp de tu empresa"
    subtitle="Conectamos un chatbot de IA a tu WhatsApp Business para que ningún mensaje quede sin respuesta, tu equipo no pierda tiempo con consultas repetitivas y los clientes queden atendidos al instante."
    ctaLabel="Ver demo en WhatsApp"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Automatización con IA', href: '/es/automatizacion-ia/' },
      { label: 'Chatbot con IA', href: '/es/automatizacion-ia/chatbot-ia/' },
      { label: 'WhatsApp', href: '/es/automatizacion-ia/chatbot-ia/whatsapp/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Funcionalidades</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Todo lo que tu chatbot de WhatsApp puede hacer</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">Mucho más que respuestas automáticas. Tu chatbot de WhatsApp entiende el contexto, gestiona procesos y se integra con tu operación.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Respuestas instantáneas 24/7', desc: 'Ningún mensaje sin respuesta, en ningún horario. Tu chatbot atiende fuera de oficina, fines de semana y festivos.' },
          { title: 'Cualificación de leads', desc: 'Hace las preguntas correctas para identificar oportunidades de venta y pasarlas a tu CRM automáticamente.' },
          { title: 'Gestión de pedidos y citas', desc: 'Acepta pedidos, confirma disponibilidad y agenda citas directamente desde WhatsApp sin intervención humana.' },
          { title: 'Catálogo interactivo', desc: 'Presenta tus productos o servicios con fotos, precios y descripciones mediante el catálogo de WhatsApp Business.' },
          { title: 'Traspaso a agentes', desc: 'Cuando la conversación lo requiere, transfiere al cliente a un agente humano con todo el contexto previo.' },
          { title: 'Integración con CRM', desc: 'Registra cada conversación, contacto y dato relevante en tu CRM de forma automática.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Cómo funciona</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">En marcha en menos de dos semanas</h2>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Onboarding y diseño', desc: 'Recogemos los flujos de conversación, preguntas frecuentes y personalidad de tu marca.' },
          { step: '02', title: 'Integración API', desc: 'Conectamos el chatbot a tu WhatsApp Business API con número propio o el tuyo.' },
          { step: '03', title: 'Entrenamiento y pruebas', desc: 'Entrenamos con tus datos reales y probamos todos los flujos antes del lanzamiento.' },
          { step: '04', title: 'Lanzamiento y mejora', desc: 'Activamos en producción y monitorizamos conversaciones para optimizar continuamente.' },
        ].map(({ step, title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <p class="text-3xl font-bold text-brand/20 mb-4">{step}</p>
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
