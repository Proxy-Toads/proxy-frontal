---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Chatbot IA para Web | ProxyToads'
const description =
  'Chatbot con IA embebido en tu web. Widget personalizable, atención 24/7, captura de leads, traspaso a agentes humanos y análisis de conversaciones en tiempo real.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Chatbot IA · Web"
    title="Convierte cada visita en una conversación"
    subtitle="Integramos un chatbot de IA en tu web que captura leads, responde preguntas frecuentes y guía a los visitantes hacia la conversión, sin que tu equipo tenga que estar presente."
    ctaLabel="Solicitar demo"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Automatización con IA', href: '/es/automatizacion-ia/' },
      { label: 'Chatbot con IA', href: '/es/automatizacion-ia/chatbot-ia/' },
      { label: 'Web', href: '/es/automatizacion-ia/chatbot-ia/web/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Funcionalidades</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Un widget que trabaja por ti mientras duermes</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">Personalizable al 100% con los colores, tono y voz de tu marca. Tus visitantes ni notarán que es un bot.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Widget personalizable', desc: 'Colores, logo, tipografía y tono de voz adaptados a tu marca. Discret o proactivo, tú decides.' },
          { title: 'Captura de leads', desc: 'Recopila nombre, email y teléfono de forma conversacional y natural, con tasas de conversión más altas que un formulario estático.' },
          { title: 'Respuestas desde tu contenido', desc: 'El chatbot aprende de tu web, documentos y FAQs para responder con información precisa y actualizada.' },
          { title: 'Soporte multilenguaje', desc: 'Detecta el idioma del visitante y responde en consecuencia. Ideal para empresas con presencia internacional.' },
          { title: 'Traspaso a agente en vivo', desc: 'Cuando el chatbot no puede resolver algo, transfiere al visitante a un agente con el contexto completo de la conversación.' },
          { title: 'Analytics de conversaciones', desc: 'Panel con métricas de uso, preguntas más frecuentes, tasa de resolución y oportunidades de mejora detectadas.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Integración</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">Funciona con tu stack actual</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: 'Una línea de código', desc: 'Instalación con un snippet de JavaScript. Compatible con cualquier web o CMS: WordPress, Webflow, Shopify, Astro…' },
          { title: 'Conexión con tu CRM', desc: 'Leads y conversaciones sincronizados automáticamente con HubSpot, Salesforce, Pipedrive y más de 50 CRMs.' },
          { title: 'Notificaciones a tu equipo', desc: 'Alertas en Slack, Teams o email cuando un lead cualificado necesita seguimiento humano.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
