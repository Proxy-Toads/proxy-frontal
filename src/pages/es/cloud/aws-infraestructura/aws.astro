---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Amazon Web Services (AWS) | ProxyToads'
const description =
  'Servicios especializados en AWS: arquitectura Well-Architected, migración a la nube, optimización de costos y gestión de infraestructura en Amazon Web Services.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AWS · Infraestructura"
    title="Expertos AWS para tu infraestructura en la nube"
    subtitle="Diseñamos, migramos y optimizamos tu infraestructura en Amazon Web Services con arquitecturas probadas, seguridad de primer nivel y costos bajo control desde el primer día."
    ctaLabel="Revisar mi arquitectura AWS"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Cloud', href: '/es/cloud/' },
      { label: 'AWS / Infraestructura', href: '/es/cloud/aws-infraestructura/' },
      { label: 'AWS', href: '/es/cloud/aws-infraestructura/aws/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Servicios AWS</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">Los servicios AWS que más impacto generan en tu negocio</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">Trabajamos con todo el ecosistema AWS, pero nos especializamos en los servicios que más valor aportan a empresas en crecimiento.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'EC2 y Auto Scaling', desc: 'Servidores virtuales con escalado automático para manejar cualquier carga sin sobreprovisionar ni quedarse sin recursos.' },
          { title: 'S3 y almacenamiento', desc: 'Almacenamiento de objetos infinitamente escalable, económico y con durabilidad del 99.999999999%.' },
          { title: 'Lambda y Serverless', desc: 'Código que se ejecuta sin gestionar servidores. Paga sólo por cada ejecución real, escala a cero cuando no se usa.' },
          { title: 'RDS y Aurora', desc: 'Bases de datos relacionales gestionadas con backups automáticos, alta disponibilidad y rendimiento optimizado.' },
          { title: 'EKS y contenedores', desc: 'Kubernetes gestionado por AWS para orquestar contenedores Docker en producción con menos operaciones.' },
          { title: 'VPC y redes', desc: 'Redes privadas virtuales aisladas con control total sobre el enrutamiento, subnets y seguridad perimetral.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Nuestros servicios</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">Cómo te ayudamos con AWS</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl">
        {[
          { title: 'Diseño de arquitectura AWS Well-Architected', desc: 'Arquitecturas que cumplen los 6 pilares del framework AWS: operaciones, seguridad, fiabilidad, rendimiento, costos y sostenibilidad.' },
          { title: 'Migración desde on-premise o entre clouds', desc: 'Migración planificada con estrategia de lift-and-shift, re-platforming o re-architecting según tu caso.' },
          { title: 'Optimización de costos', desc: 'Auditoría de tu cuenta AWS, rightsizing de instancias, uso de Savings Plans y eliminación de recursos olvidados.' },
          { title: 'Gestión y operaciones', desc: 'Monitoring, alertas, gestión de incidencias y actualizaciones de infraestructura continua para que tú te olvides de los servidores.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
