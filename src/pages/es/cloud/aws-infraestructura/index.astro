---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'AWS e Infraestructura Cloud | ProxyToads'
const description =
  'Arquitectura, migración y gestión de infraestructura en AWS. Diseñamos entornos cloud seguros, escalables y rentables adaptados a las necesidades de tu empresa.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AWS / Infraestructura"
    title="Infraestructura AWS diseñada para escalar sin sorpresas"
    subtitle="Diseñamos y gestionamos arquitecturas en Amazon Web Services que se adaptan al crecimiento de tu empresa con alta disponibilidad, seguridad probada y costos controlados."
    ctaLabel="Revisar mi arquitectura"
    ctaHref="mailto:hello@proxytoads.com"
    ctaSecondaryLabel="Ver proveedores"
    ctaSecondaryHref="#proveedores"
    breadcrumb={[
      { label: 'Cloud', href: '/es/cloud/' },
      { label: 'AWS / Infraestructura', href: '/es/cloud/aws-infraestructura/' },
    ]}
  />

  <section id="proveedores" class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Proveedores</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Expertos certificados en los tres grandes proveedores cloud</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">Trabajamos con AWS, Azure y GCP para que siempre uses el proveedor que mejor se adapta a tus necesidades, sin ataduras.</p>

      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <a href="/es/cloud/aws-infraestructura/aws/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">AWS</h3>
          <p class="text-dim leading-relaxed mb-4">El líder del mercado cloud. EC2, S3, Lambda, RDS, EKS y todo el ecosistema de Amazon para infraestructuras de cualquier tamaño.</p>
          <span class="text-brand text-sm font-medium">Ver más →</span>
        </a>

        <a href="/es/cloud/aws-infraestructura/azure-gcp/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">Azure / GCP</h3>
          <p class="text-dim leading-relaxed mb-4">Microsoft Azure para entornos Microsoft y Google Cloud Platform para IA y analytics de vanguardia. Estrategia multi-cloud si tu caso lo requiere.</p>
          <span class="text-brand text-sm font-medium">Ver más →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Servicios de infraestructura</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">Todo lo que tu infraestructura cloud necesita</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Diseño de arquitectura', desc: 'Arquitecturas Well-Architected que equilibran costo, rendimiento, seguridad y operatividad.' },
          { title: 'Migración a cloud', desc: 'Migración segura desde on-premise o entre proveedores cloud con cero tiempo de inactividad.' },
          { title: 'Optimización de costos', desc: 'Auditoría y ajuste de recursos para eliminar gasto innecesario y dimensionar correctamente.' },
          { title: 'Alta disponibilidad', desc: 'Diseño multi-zona, auto-scaling y balanceo de carga para garantizar el 99.9% de uptime.' },
          { title: 'Bases de datos gestionadas', desc: 'RDS, Aurora, DynamoDB y otras opciones configuradas para rendimiento y recuperación ante desastres.' },
          { title: 'Redes y seguridad perimetral', desc: 'VPC, subnets, security groups, WAF y gestión de certificados para aislar y proteger tu infraestructura.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
