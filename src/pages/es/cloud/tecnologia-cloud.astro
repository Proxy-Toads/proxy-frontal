---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Tecnología Cloud | ProxyToads'
const description =
  'Adopción de tecnología cloud-native: contenedores Docker, Kubernetes, microservicios y arquitecturas serverless. Plataformas modernas que escalan con tu negocio.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Tecnología Cloud"
    title="Cloud-native: la infraestructura que crece con tu empresa"
    subtitle="Adoptamos las mejores tecnologías cloud para modernizar tu plataforma técnica: contenedores, orquestación, microservicios y arquitecturas serverless que escalan a demanda."
    ctaLabel="Evaluar mi plataforma"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Cloud', href: '/es/cloud/' },
      { label: 'Tecnología Cloud', href: '/es/cloud/tecnologia-cloud/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Tecnologías</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">El stack cloud moderno para empresas que escalan</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">Seleccionamos e implementamos las tecnologías cloud que más valor aportan a tu caso, sin sobreingeniería ni complejidad innecesaria.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Contenedores Docker', desc: 'Empaquetamos tus aplicaciones en contenedores portables que funcionan igual en desarrollo, staging y producción.' },
          { title: 'Kubernetes (K8s)', desc: 'Orquestación de contenedores para despliegue, escalado automático y recuperación de servicios sin intervención manual.' },
          { title: 'Arquitectura de microservicios', desc: 'División de monolitos en servicios independientes para escalar, desplegar y mantener cada parte de forma autónoma.' },
          { title: 'Serverless y Functions', desc: 'Lambda, Cloud Functions y Azure Functions para código que sólo paga cuando se ejecuta y escala automáticamente.' },
          { title: 'Service mesh', desc: 'Istio y Linkerd para gestión de tráfico, observabilidad y seguridad entre microservicios en producción.' },
          { title: 'CDN y edge computing', desc: 'Distribución de contenido globalmente con CloudFront, Cloudflare y otros para latencias mínimas desde cualquier lugar.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-brand mb-2">0s</p>
        <p class="text-dim text-sm">Downtime en despliegues</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">∞</p>
        <p class="text-dim text-sm">Escalado automático</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">−50%</p>
        <p class="text-dim text-sm">Tiempo de despliegue</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">100%</p>
        <p class="text-dim text-sm">Portabilidad entre clouds</p>
      </div>
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Para quién es</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">Ideal si tu empresa está en alguna de estas situaciones</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl">
        {[
          'Tu aplicación tiene problemas de rendimiento en picos de tráfico',
          'Los despliegues son lentos, manuales o generan downtime',
          'Quieres escalar internacionalmente sin reconstruir la infraestructura',
          'Tu equipo necesita entornos de desarrollo consistentes con producción',
          'Tienes servicios interdependientes difíciles de actualizar por separado',
          'Quieres reducir costos pagando solo por lo que realmente consumes',
        ].map(item => (
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-brand/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-dim">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
