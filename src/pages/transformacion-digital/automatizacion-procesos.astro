---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Process Automation | Digital Transformation | ProxyToads'
const description =
  'Automate your business operations with digital workflows, system integrations and software robots. More efficiency, fewer errors, more productive teams.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Process Automation"
    title="Faster processes, more productive teams"
    subtitle="We automate your company's operational processes to reduce errors, accelerate timelines and free your team from mechanical work so they can focus on what creates real value."
    ctaLabel="Free analysis"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Digital Transformation', href: '/transformacion-digital/' },
      { label: 'Process Automation', href: '/transformacion-digital/automatizacion-procesos/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">What we automate</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Any repetitive process can be automated</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">If your team performs the same task more than twice a week following fixed steps, we can probably automate it.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Order management', desc: 'Automatic order reception, validation, assignment and tracking with no human involvement.' },
          { title: 'Approvals & internal flows', desc: 'Approval, review and document signing workflows — no emails, no bottlenecks.' },
          { title: 'Reports & dashboards', desc: 'Automatic generation of periodic reports with up-to-date data from all your sources.' },
          { title: 'Customer support', desc: 'Automatic replies, intelligent escalation and incident logging without manual work.' },
          { title: 'Human resources', desc: 'Employee onboarding, leave management and internal communications automated end to end.' },
          { title: 'Accounting & payments', desc: 'Payment reconciliation, invoice generation and due-date alerts without intervention.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-brand mb-2">−90%</p>
        <p class="text-dim text-sm">Process errors</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">5×</p>
        <p class="text-dim text-sm">Execution speed</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">24/7</p>
        <p class="text-dim text-sm">Active processes</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">£0</p>
        <p class="text-dim text-sm">Cost of saved hours</p>
      </div>
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Technologies</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">The right tools for every type of automation</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: 'n8n and Make', desc: 'For app-to-app integration workflows and no-code automations of medium complexity.' },
          { title: 'Python & APIs', desc: 'For complex custom automations requiring specific business logic.' },
          { title: 'RPA (Robotic Process Automation)', desc: 'For automating tasks in legacy applications or interfaces with no API available.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
