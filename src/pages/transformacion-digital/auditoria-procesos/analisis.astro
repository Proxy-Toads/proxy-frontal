---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'Process Analysis | Audit | ProxyToads'
const description =
  'In-depth analysis of your business processes. Flow mapping, team interviews, inefficiency identification and a complete diagnosis to prepare your digital transformation.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="Analysis · Process Audit"
    title="A complete X-ray of how your business operates"
    subtitle="We carry out a detailed analysis of every key process to understand where time and money are being lost, which tools are underused and where the best improvement opportunities lie."
    ctaLabel="Request an analysis"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'Digital Transformation', href: '/transformacion-digital/' },
      { label: 'Process Audit', href: '/transformacion-digital/auditoria-procesos/' },
      { label: 'Analysis', href: '/transformacion-digital/auditoria-procesos/analisis/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Methodology</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">How we carry out the analysis</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">We combine team interviews, direct process observation and data analysis to build an objective, complete picture.</p>

      <div class="grid md:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Kick-off & scope', desc: 'We define which processes to analyse, who is involved and the concrete objectives of the diagnosis.' },
          { step: '02', title: 'Interviews & observation', desc: 'We talk to the people who execute processes every day to capture reality, not just the manual.' },
          { step: '03', title: 'As-Is mapping', desc: 'We visually document each process with its steps, actors, tools and identified pain points.' },
          { step: '04', title: 'Diagnosis & prioritisation', desc: 'We quantify the impact of each inefficiency and prioritise opportunities by effort and return.' },
        ].map(({ step, title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <p class="text-3xl font-bold text-brand/20 mb-4">{step}</p>
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Deliverables</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">What you receive when the analysis is complete</h2>
      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl">
        {[
          { title: 'As-Is process maps', desc: 'Detailed diagrams of each analysed process with actors, tools, steps and friction points.' },
          { title: 'Inefficiency report', desc: 'Quantified list of issues: time lost, frequent errors, duplications and low-value tasks.' },
          { title: 'Tool analysis', desc: "Assessment of what tools you use, which are redundant, which are missing and which integrations would improve the operation." },
          { title: 'Executive summary', desc: 'Presentation of the most important findings for your leadership team in clear language focused on business impact.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
