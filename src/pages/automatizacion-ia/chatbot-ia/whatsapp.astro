---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'AI Chatbot for WhatsApp | ProxyToads'
const description =
  'AI chatbot for WhatsApp Business. Automated 24/7 responses, lead qualification, order management and CRM integration with personalised conversation flows.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AI Chatbot · WhatsApp"
    title="Your AI assistant inside your company's WhatsApp"
    subtitle="We connect an AI chatbot to your WhatsApp Business so no message goes unanswered, your team stops losing time on repetitive queries and customers get instant attention."
    ctaLabel="See WhatsApp demo"
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: 'AI Automation', href: '/automatizacion-ia/' },
      { label: 'AI Chatbot', href: '/automatizacion-ia/chatbot-ia/' },
      { label: 'WhatsApp', href: '/automatizacion-ia/chatbot-ia/whatsapp/' },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl mx-auto text-center">Everything your WhatsApp chatbot can do</h2>
      <p class="text-dim text-lg max-w-2xl mx-auto mb-16 text-center">Much more than auto-replies. Your WhatsApp chatbot understands context, manages processes and integrates with your operation.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Instant replies 24/7', desc: 'No message left unanswered, at any hour. Your chatbot handles messages outside office hours, weekends and holidays.' },
          { title: 'Lead qualification', desc: 'Asks the right questions to identify sales opportunities and automatically passes them to your CRM.' },
          { title: 'Order & appointment management', desc: 'Accepts orders, confirms availability and books appointments directly from WhatsApp without human intervention.' },
          { title: 'Interactive catalogue', desc: 'Showcases your products or services with photos, prices and descriptions via the WhatsApp Business catalogue.' },
          { title: 'Handoff to agents', desc: 'When the conversation requires it, transfers the customer to a human agent with full prior context included.' },
          { title: 'CRM integration', desc: 'Automatically logs every conversation, contact and relevant data point to your CRM.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line bg-surface">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4 text-center">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl mx-auto text-center">Up and running in under two weeks</h2>
      <div class="grid md:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Onboarding & design', desc: 'We gather your conversation flows, FAQs and brand personality.' },
          { step: '02', title: 'API integration', desc: 'We connect the chatbot to your WhatsApp Business API with your own number or ours.' },
          { step: '03', title: 'Training & testing', desc: 'We train with your real data and test all flows before going live.' },
          { step: '04', title: 'Launch & improve', desc: 'We activate in production and monitor conversations to continuously optimise.' },
        ].map(({ step, title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <p class="text-3xl font-bold text-brand/20 mb-4">{step}</p>
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
