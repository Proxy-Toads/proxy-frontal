---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'AI Chatbot | Automation | ProxyToads'
const description =
  'Intelligent AI chatbots for WhatsApp and web. 24/7 customer service with natural language understanding, CRM integration and personalised conversation flows.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AI Chatbot"
    title="Chatbots that speak like humans, work like machines"
    subtitle="We build AI-powered conversational assistants that understand natural language and give accurate answers to your customers on any channel, at any hour."
    ctaLabel="Request a demo"
    ctaHref="mailto:hello@proxytoads.com"
    ctaSecondaryLabel="See channels"
    ctaSecondaryHref="#channels"
    breadcrumb={[
      { label: 'AI Automation', href: '/automatizacion-ia/' },
      { label: 'AI Chatbot', href: '/automatizacion-ia/chatbot-ia/' },
    ]}
  />

  <section id="channels" class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Available channels</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">Where your customers are, your chatbot is too</h2>
      <p class="text-dim text-lg max-w-2xl mb-16">We deploy your AI assistant on the channels your customers already use, with no friction or platform changes.</p>

      <div class="grid md:grid-cols-2 gap-8 max-w-3xl">
        <a href="/automatizacion-ia/chatbot-ia/whatsapp/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">WhatsApp</h3>
          <p class="text-dim leading-relaxed mb-4">Chatbot connected to your WhatsApp Business. Responds automatically, manages orders and qualifies leads without any human involvement.</p>
          <span class="text-brand text-sm font-medium">Learn more →</span>
        </a>

        <a href="/automatizacion-ia/chatbot-ia/web/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">Web</h3>
          <p class="text-dim leading-relaxed mb-4">Chat widget embedded on your website. Captures leads, answers questions and guides visitors toward conversion while you sleep.</p>
          <span class="text-brand text-sm font-medium">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Capabilities</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">What your chatbot can do</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Natural language understanding', desc: 'Understands questions with typos, variations and context — just like a human would.' },
          { title: 'Multi-turn conversations', desc: 'Maintains context throughout the entire conversation, not just the last message.' },
          { title: 'Human handoff', desc: 'Detects when to transfer the conversation to a live agent with full context included.' },
          { title: 'CRM integration', desc: 'Automatically logs leads, updates contacts and syncs data with your CRM.' },
          { title: 'Document-based answers', desc: 'Responds using your documents, FAQs, catalogues and knowledge bases.' },
          { title: 'Conversation analytics', desc: 'Dashboard with usage metrics, top questions and AI-detected improvement opportunities.' },
        ].map(({ title, desc }) => (
          <div class="p-6 rounded-xl border border-line">
            <h3 class="font-semibold text-ink mb-2">{title}</h3>
            <p class="text-dim text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
