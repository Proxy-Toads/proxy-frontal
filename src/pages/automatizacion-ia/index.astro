---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'

const title = 'AI Automation | ProxyToads'
const description =
  'Automate repetitive tasks with Artificial Intelligence. AI chatbots, AI tools and n8n workflows for businesses of any size. More productivity from day one.'
---

<PageLayout title={title} description={description}>
  <PageHero
    eyebrow="AI Automation"
    title="Turn AI into your biggest competitive advantage"
    subtitle="We design AI-powered automation solutions that eliminate repetitive work, accelerate processes and free your team to focus on what truly matters."
    ctaLabel="Talk to an expert"
    ctaHref="mailto:hello@proxytoads.com"
    ctaSecondaryLabel="See solutions"
    ctaSecondaryHref="#solutions"
    breadcrumb={[{ label: 'AI Automation', href: '/automatizacion-ia/' }]}
  />

  <section id="solutions" class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Our solutions</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 max-w-2xl">
        End-to-end intelligent automation
      </h2>
      <p class="text-dim text-lg max-w-2xl mb-16">
        From your first chatbot to complex automation workflows, we guide your business through every step of the transformation.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <a href="/automatizacion-ia/chatbot-ia/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">AI Chatbot</h3>
          <p class="text-dim leading-relaxed mb-4">Conversational assistants for WhatsApp and web that serve your customers 24/7 with accurate, natural responses.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>

        <a href="/automatizacion-ia/herramientas-ia/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">AI Tools</h3>
          <p class="text-dim leading-relaxed mb-4">We implement and configure the best AI tools on the market, tailored to your industry and specific workflows.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>

        <a href="/automatizacion-ia/flujos-n8n/" class="group p-8 rounded-xl border border-line hover:border-brand/50 transition-colors bg-surface">
          <div class="w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3 group-hover:text-brand transition-colors">n8n Workflows</h3>
          <p class="text-dim leading-relaxed mb-4">Complex automations with n8n that connect all your apps and eliminate manual work between systems.</p>
          <span class="text-brand text-sm font-medium">Explore →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-brand mb-2">70%</p>
        <p class="text-dim text-sm">Reduction in manual work</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">24/7</p>
        <p class="text-dim text-sm">Automated availability</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">+500</p>
        <p class="text-dim text-sm">Workflows deployed</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-brand mb-2">3×</p>
        <p class="text-dim text-sm">Team productivity</p>
      </div>
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand text-sm font-medium uppercase tracking-wider mb-4">Why choose us</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-12 max-w-xl">
        AI that delivers real results, not just demos
      </h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl">
        {[
          'Custom solutions, not generic templates',
          'Integration with your existing systems and tools',
          'Fast implementation: results in weeks, not months',
          'Continuous support and iterative performance improvement',
          'Expert team in AI, automation and data architecture',
          'Demonstrable ROI within the first 90 days',
        ].map(item => (
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-brand/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-dim">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
