---
interface Props {
  href: string
  variant?: 'primary' | 'outline'
  class?: string
}

const { href, variant = 'primary', class: className } = Astro.props

const variants = {
  primary: 'bg-brand text-canvas hover:bg-brand-light',
  outline: 'border border-line text-ink hover:border-brand/50',
}
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-2 px-8 py-3 rounded-lg font-medium transition-colors group',
    variants[variant],
    className,
  ]}
>
  <slot />
</a>
