---
interface Props {
  href?: string
  class?: string
}

const { href, class: className } = Astro.props
const base = 'p-6 rounded-xl border border-line bg-surface hover:border-brand/40 transition-colors group'
---

{href ? (
  <a href={href} class:list={[base, className]}>
    <slot />
  </a>
) : (
  <div class:list={[base, className]}>
    <slot />
  </div>
)}
