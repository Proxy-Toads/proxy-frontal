---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { Icon } from 'astro-icon/components'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
const base = lang === 'en' ? '' : `/${lang}`

const areas = [
  { title: t('pg.sme.a1.title'), desc: t('pg.sme.a1.desc') },
  { title: t('pg.sme.a2.title'), desc: t('pg.sme.a2.desc') },
  { title: t('pg.sme.a3.title'), desc: t('pg.sme.a3.desc') },
  { title: t('pg.sme.a4.title'), desc: t('pg.sme.a4.desc') },
  { title: t('pg.sme.a5.title'), desc: t('pg.sme.a5.desc') },
  { title: t('pg.sme.a6.title'), desc: t('pg.sme.a6.desc') },
]

const stats = [
  { val: t('pg.sme.stat.1.val'), label: t('pg.sme.stat.1.label') },
  { val: t('pg.sme.stat.2.val'), label: t('pg.sme.stat.2.label') },
  { val: t('pg.sme.stat.3.val'), label: t('pg.sme.stat.3.label') },
  { val: t('pg.sme.stat.4.val'), label: t('pg.sme.stat.4.label') },
]

const why = [t('pg.sme.why.1'), t('pg.sme.why.2'), t('pg.sme.why.3'), t('pg.sme.why.4'), t('pg.sme.why.5'), t('pg.sme.why.6')]
---

<PageLayout title={t('pg.sme.meta.title')} description={t('pg.sme.meta.desc')}>
  <PageHero
    eyebrow={t('pg.sme.hero.eyebrow')}
    title={t('pg.sme.hero.title')}
    subtitle={t('pg.sme.hero.sub')}
    ctaLabel={t('pg.sme.hero.cta1')}
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: t('pg.dt.hero.eyebrow'), href: `${base}/transformacion-digital/` },
      { label: t('pg.sme.hero.eyebrow'), href: `${base}/transformacion-digital/digitalizacion-pymes/` },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.sme.areas.eyebrow')} headline={t('pg.sme.areas.title')} sub={t('pg.sme.areas.sub')} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map(a => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{a.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{a.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map(s => (
        <div>
          <p class="text-4xl font-bold text-brand mb-2">{s.val}</p>
          <p class="text-dim text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.sme.why.eyebrow')} headline={t('pg.sme.why.title')} />
      <ul class="grid md:grid-cols-2 gap-4 max-w-3xl mx-auto">
        {why.map(item => (
          <li class="flex items-center gap-3">
            <span class="w-5 h-5 rounded-full bg-brand/15 flex items-center justify-center shrink-0">
              <Icon name="lucide:check" class="w-3 h-3 text-brand" />
            </span>
            <span class="text-dim">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</PageLayout>
