---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
const base = lang === 'en' ? '' : `/${lang}`

const features = [
  { title: t('pg.wa.f1.title'), desc: t('pg.wa.f1.desc') },
  { title: t('pg.wa.f2.title'), desc: t('pg.wa.f2.desc') },
  { title: t('pg.wa.f3.title'), desc: t('pg.wa.f3.desc') },
  { title: t('pg.wa.f4.title'), desc: t('pg.wa.f4.desc') },
  { title: t('pg.wa.f5.title'), desc: t('pg.wa.f5.desc') },
  { title: t('pg.wa.f6.title'), desc: t('pg.wa.f6.desc') },
]

const steps = [
  { num: t('pg.wa.step.1.num'), title: t('pg.wa.step.1.title'), desc: t('pg.wa.step.1.desc') },
  { num: t('pg.wa.step.2.num'), title: t('pg.wa.step.2.title'), desc: t('pg.wa.step.2.desc') },
  { num: t('pg.wa.step.3.num'), title: t('pg.wa.step.3.title'), desc: t('pg.wa.step.3.desc') },
  { num: t('pg.wa.step.4.num'), title: t('pg.wa.step.4.title'), desc: t('pg.wa.step.4.desc') },
]
---

<PageLayout title={t('pg.wa.meta.title')} description={t('pg.wa.meta.desc')}>
  <PageHero
    eyebrow={t('pg.wa.hero.eyebrow')}
    title={t('pg.wa.hero.title')}
    subtitle={t('pg.wa.hero.sub')}
    ctaLabel={t('pg.wa.hero.cta1')}
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: t('pg.ai.hero.eyebrow'), href: `${base}/automatizacion-ia/` },
      { label: t('pg.chatbot.hero.eyebrow'), href: `${base}/automatizacion-ia/chatbot-ia/` },
      { label: t('pg.chatbot.ch.1.title'), href: `${base}/automatizacion-ia/chatbot-ia/whatsapp/` },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.wa.feat.eyebrow')} headline={t('pg.wa.feat.title')} sub={t('pg.wa.feat.sub')} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{f.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{f.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.wa.how.eyebrow')} headline={t('pg.wa.how.title')} />
      <div class="grid md:grid-cols-4 gap-6">
        {steps.map(s => (
          <Card>
            <p class="text-3xl font-bold text-brand/20 mb-4">{s.num}</p>
            <h3 class="font-semibold text-ink mb-2">{s.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{s.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
