---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
const base = lang === 'en' ? '' : `/${lang}`

const cases = [
  { title: t('pg.n8n.c1.title'), desc: t('pg.n8n.c1.desc') },
  { title: t('pg.n8n.c2.title'), desc: t('pg.n8n.c2.desc') },
  { title: t('pg.n8n.c3.title'), desc: t('pg.n8n.c3.desc') },
  { title: t('pg.n8n.c4.title'), desc: t('pg.n8n.c4.desc') },
  { title: t('pg.n8n.c5.title'), desc: t('pg.n8n.c5.desc') },
  { title: t('pg.n8n.c6.title'), desc: t('pg.n8n.c6.desc') },
]

const stats = [
  { val: t('pg.n8n.stat.1.val'), label: t('pg.n8n.stat.1.label') },
  { val: t('pg.n8n.stat.2.val'), label: t('pg.n8n.stat.2.label') },
  { val: t('pg.n8n.stat.3.val'), label: t('pg.n8n.stat.3.label') },
  { val: t('pg.n8n.stat.4.val'), label: t('pg.n8n.stat.4.label') },
]

const integrations = ['HubSpot', 'Salesforce', 'Gmail', 'Slack', 'Notion', 'Airtable', 'Google Sheets', 'WhatsApp Business', 'Stripe', 'Shopify', 'WordPress', 'PostgreSQL', 'MySQL', 'OpenAI', 'Anthropic Claude', 'Zapier', 'Typeform', 'Calendly', 'Twilio', 'Mailchimp']
---

<PageLayout title={t('pg.n8n.meta.title')} description={t('pg.n8n.meta.desc')}>
  <PageHero
    eyebrow={t('pg.n8n.hero.eyebrow')}
    title={t('pg.n8n.hero.title')}
    subtitle={t('pg.n8n.hero.sub')}
    ctaLabel={t('pg.n8n.hero.cta1')}
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: t('pg.ai.hero.eyebrow'), href: `${base}/automatizacion-ia/` },
      { label: t('pg.n8n.hero.eyebrow'), href: `${base}/automatizacion-ia/flujos-n8n/` },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.n8n.cases.eyebrow')} headline={t('pg.n8n.cases.title')} sub={t('pg.n8n.cases.sub')} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {cases.map(c => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{c.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{c.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map(s => (
        <div>
          <p class="text-4xl font-bold text-brand mb-2">{s.val}</p>
          <p class="text-dim text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.n8n.int.eyebrow')} headline={t('pg.n8n.int.title')} />
      <div class="flex flex-wrap justify-center gap-3">
        {integrations.map(tool => (
          <span class="px-4 py-2 rounded-full border border-line bg-surface text-dim text-sm">{tool}</span>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
