---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { Icon } from 'astro-icon/components'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
const base = lang === 'en' ? '' : `/${lang}`

const technologies = [
  { title: t('pg.ctech.t1.title'), desc: t('pg.ctech.t1.desc') },
  { title: t('pg.ctech.t2.title'), desc: t('pg.ctech.t2.desc') },
  { title: t('pg.ctech.t3.title'), desc: t('pg.ctech.t3.desc') },
  { title: t('pg.ctech.t4.title'), desc: t('pg.ctech.t4.desc') },
  { title: t('pg.ctech.t5.title'), desc: t('pg.ctech.t5.desc') },
  { title: t('pg.ctech.t6.title'), desc: t('pg.ctech.t6.desc') },
]

const stats = [
  { val: t('pg.ctech.stat.1.val'), label: t('pg.ctech.stat.1.label') },
  { val: t('pg.ctech.stat.2.val'), label: t('pg.ctech.stat.2.label') },
  { val: t('pg.ctech.stat.3.val'), label: t('pg.ctech.stat.3.label') },
  { val: t('pg.ctech.stat.4.val'), label: t('pg.ctech.stat.4.label') },
]

const forWhom = [t('pg.ctech.for.1'), t('pg.ctech.for.2'), t('pg.ctech.for.3'), t('pg.ctech.for.4'), t('pg.ctech.for.5'), t('pg.ctech.for.6')]
---

<PageLayout title={t('pg.ctech.meta.title')} description={t('pg.ctech.meta.desc')}>
  <PageHero
    eyebrow={t('pg.ctech.hero.eyebrow')}
    title={t('pg.ctech.hero.title')}
    subtitle={t('pg.ctech.hero.sub')}
    ctaLabel={t('pg.ctech.hero.cta1')}
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: t('pg.cloud.hero.eyebrow'), href: `${base}/cloud/` },
      { label: t('pg.ctech.hero.eyebrow'), href: `${base}/cloud/tecnologia-cloud/` },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.ctech.tech.eyebrow')} headline={t('pg.ctech.tech.title')} sub={t('pg.ctech.tech.sub')} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {technologies.map(tech => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{tech.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{tech.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map(s => (
        <div>
          <p class="text-4xl font-bold text-brand mb-2">{s.val}</p>
          <p class="text-dim text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.ctech.for.eyebrow')} headline={t('pg.ctech.for.title')} />
      <ul class="grid md:grid-cols-2 gap-4 max-w-3xl mx-auto">
        {forWhom.map(item => (
          <li class="flex items-center gap-3">
            <span class="w-5 h-5 rounded-full bg-brand/15 flex items-center justify-center shrink-0">
              <Icon name="lucide:check" class="w-3 h-3 text-brand" />
            </span>
            <span class="text-dim">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</PageLayout>
