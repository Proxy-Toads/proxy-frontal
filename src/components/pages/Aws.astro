---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/PageHero.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
const base = lang === 'en' ? '' : `/${lang}`

const services = [
  { title: t('pg.aws.s1.title'), desc: t('pg.aws.s1.desc') },
  { title: t('pg.aws.s2.title'), desc: t('pg.aws.s2.desc') },
  { title: t('pg.aws.s3.title'), desc: t('pg.aws.s3.desc') },
  { title: t('pg.aws.s4.title'), desc: t('pg.aws.s4.desc') },
  { title: t('pg.aws.s5.title'), desc: t('pg.aws.s5.desc') },
  { title: t('pg.aws.s6.title'), desc: t('pg.aws.s6.desc') },
]

const howItems = [
  { title: t('pg.aws.h1.title'), desc: t('pg.aws.h1.desc') },
  { title: t('pg.aws.h2.title'), desc: t('pg.aws.h2.desc') },
  { title: t('pg.aws.h3.title'), desc: t('pg.aws.h3.desc') },
  { title: t('pg.aws.h4.title'), desc: t('pg.aws.h4.desc') },
]
---

<PageLayout title={t('pg.aws.meta.title')} description={t('pg.aws.meta.desc')}>
  <PageHero
    eyebrow={t('pg.aws.hero.eyebrow')}
    title={t('pg.aws.hero.title')}
    subtitle={t('pg.aws.hero.sub')}
    ctaLabel={t('pg.aws.hero.cta1')}
    ctaHref="mailto:hello@proxytoads.com"
    breadcrumb={[
      { label: t('pg.cloud.hero.eyebrow'), href: `${base}/cloud/` },
      { label: t('pg.infra.hero.eyebrow'), href: `${base}/cloud/aws-infraestructura/` },
      { label: t('pg.infra.prov.1.title'), href: `${base}/cloud/aws-infraestructura/aws/` },
    ]}
  />

  <section class="py-section px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.aws.svc.eyebrow')} headline={t('pg.aws.svc.title')} sub={t('pg.aws.svc.sub')} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{s.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{s.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section px-6 bg-surface border-t border-b border-line">
    <div class="max-w-6xl mx-auto">
      <SectionHeader eyebrow={t('pg.aws.how.eyebrow')} headline={t('pg.aws.how.title')} />
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {howItems.map(h => (
          <Card>
            <h3 class="font-semibold text-ink mb-2">{h.title}</h3>
            <p class="text-sm text-dim leading-relaxed">{h.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
