---
import { Icon } from 'astro-icon/components'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Card from '@/components/ui/Card.astro'
import { useTranslations } from '@/i18n/utils'
import type { Lang } from '@/i18n/utils'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)

const services = [
  { icon: 'lucide:bot', title: t('services.1.title'), desc: t('services.1.desc') },
  { icon: 'lucide:workflow', title: t('services.2.title'), desc: t('services.2.desc') },
  { icon: 'lucide:brain-circuit', title: t('services.3.title'), desc: t('services.3.desc') },
  { icon: 'lucide:message-square', title: t('services.4.title'), desc: t('services.4.desc') },
  { icon: 'lucide:zap', title: t('services.5.title'), desc: t('services.5.desc') },
  { icon: 'lucide:settings-2', title: t('services.6.title'), desc: t('services.6.desc') },
]
---

<section id="services" class="py-section px-6">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      eyebrow={t('services.eyebrow')}
      headline={t('services.headline')}
      sub={t('services.sub')}
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <Card>
          <div class="w-11 h-11 rounded-lg bg-brand/10 flex items-center justify-center mb-4 group-hover:bg-brand/20 transition-colors">
            <Icon name={service.icon} class="w-5 h-5 text-brand" />
          </div>
          <h3 class="font-semibold text-ink mb-2">{service.title}</h3>
          <p class="text-sm text-dim leading-relaxed">{service.desc}</p>
        </Card>
      ))}
    </div>
  </div>
</section>
